# Google Sheets server credentials
GOOGLE_SHEET_ID=10kwcEYyyOA3tIKTpmdwH21KIdpidLaiU04RC6ON6tJE
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
PRODUCT_MEDIA_ORIGIN=https://pub-152b30e9e62f4e82aa0893fd90576e96.r2.dev

# Admin password authentication. Store only the generated PBKDF2 hash and a
# random secret with at least 32 bytes. Never put the plain password here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_AUTH_SECRET=
ADMIN_PASSWORD_FALLBACK_ENABLED=true

# Cloudflare Access (production admin login). Keep the email allowlist in a
# Worker secret rather than Git because it contains personal information.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=
ADMIN_ALLOWED_EMAILS=

# Non-secret build settings used only by `npm run build:cloudflare`.
CLOUDFLARE_CUSTOM_DOMAIN=
CLOUDFLARE_R2_BUCKET_NAME=jae-noi-pork-shop-uploads
CLOUDFLARE_PRODUCT_MEDIA_BUCKET_NAME=jae-noi-pork-shop-media

# SlipOK stays disabled until the account is registered, the receiving bank
# account is bound, abuse protection is reviewed, and a real slip test passes.
SLIPOK_ENABLED=false
SLIPOK_BRANCH_ID=
SLIPOK_API_KEY=
